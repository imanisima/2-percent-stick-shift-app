---
const { title } = Astro.props as { title: string };
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} · StickShift Marketplace` : 'StickShift Marketplace'}</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="container">
        <a class="brand" href="/">StickShift Marketplace</a>
        <nav>
          <a href="/">Listings</a>
          <a href="/create">Create Listing</a>
          <a href="/saved-searches">Saved Searches</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <span>Local MVP built with Astro</span>
      </div>
    </footer>
  </body>
</html>
